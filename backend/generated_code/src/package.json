{
  "name": "task-manager",
  "version": "1.0.0",
  "scripts": {
    "start": "node src/backend/app.js",
    "build": "npm run build:frontend",
    "build:frontend": "npm run --prefix src/frontend build",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "npm run --prefix src/frontend test:unit",
    "test:integration": "npm run --prefix src/frontend test:integration"
  },
  "dependencies": {
    "express": "^4.17.1",
    "mongoose": "^5.10.15",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^8.5.1",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "redux": "^4.0.5",
    "react-redux": "^7.2.2"
  },
  "devDependencies": {
    "@babel/core": "^7.12.10",
    "@babel/preset-env": "^7.12.11",
    "@babel/preset-react": "^7.12.10",
    "babel-loader": "^8.2.2",
    "webpack": "^5.24.2",
    "webpack-cli": "^4.5.0"
  }
}