{
  "name": "agentic-code-editor",
  "version": "1.0.0",
  "description": "AI-Powered Desktop Code Editor with Agentic AI",
  "main": "electron/main.js",
  "scripts": {
    "frontend": "cd frontend && npm run dev",
    "backend": "cd backend && python -u main.py",
    "electron": "wait-on http://localhost:5173 && electron .",
    "start": "concurrently \"npm run backend\" \"npm run frontend\" \"npm run electron\"",
    "build": "cd frontend && npm run build",
    "build:exe": "electron-builder build --win --x64",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "electron",
    "react",
    "monaco",
    "ai",
    "code-editor"
  ],
  "author": "Antigravity AI",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0",
    "openai": "^6.39.0"
  },
  "build": {
    "appId": "com.antigravity.agentic-code-editor",
    "productName": "Neuro Code Editor",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "frontend/build/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "frontend/public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
